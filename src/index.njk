      <img src="/assets/cpdmed.jpg" alt="CPD Med" class="ticker-logo">
      <img src="/assets/startup-karnataka.jpg" alt="Startup Karnataka" class="ticker-logo">
      <img src="/assets/ktech.jpg" alt="KITS" class="ticker-logo">
      <img src="/assets/make-in-india.jpg" alt="Make in India" class="ticker-logo">
      <img src="/assets/dpiit.jpg" alt="DPIIT" class="ticker-logo">
      <img src="/assets/birac.jpg" alt="BIRAC" class="ticker-logo">
      <img src="/assets/ccamp.jpg" alt="C-CAMP" class="ticker-logo">
    </div>
    <div class="ticker-set" aria-hidden="true">
      <img src="/assets/cpdmed.jpg" alt="CPD Med" class="ticker-logo">
      <img src="/assets/startup-karnataka.jpg" alt="Startup Karnataka" class="ticker-logo">
      <img src="/assets/ktech.jpg" alt="KITS" class="ticker-logo">
      <img src="/assets/make-in-india.jpg" alt="Make in India" class="ticker-logo">
      <img src="/assets/dpiit.jpg" alt="DPIIT" class="ticker-logo">
