<style>
  .ds-page { max-width: 1120px; margin: 0 auto; padding: 64px 24px 120px; }
  .ds-header { border-bottom: 2px solid var(--color-navy-100); padding-bottom: 32px; margin-bottom: 64px; }
  .ds-title { font-family: var(--font-heading); font-size: 48px; color: var(--color-navy-800); margin-bottom: 8px; }
  .ds-subtitle { font-family: var(--font-body); font-size: 16px; color: #6b7280; margin: 0; }
  .ds-section { margin-bottom: 80px; }
  .ds-section-title { font-family: var(--font-heading); font-size: 28px; color: var(--color-navy-800); margin-bottom: 4px; }
  .ds-section-desc { font-family: var(--font-body); font-size: 14px; color: #6b7280; margin-bottom: 28px; }
  .ds-label { font-family: var(--font-body); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #9ca3af; margin-bottom: 8px; }
  .ds-row { display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-start; }
  .ds-col { flex: 1; min-width: 260px; }

  /* Swatch grid */
  .ds-swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(88px, 1fr)); gap: 12px; }
  .ds-swatch { border-radius: 10px; overflow: hidden; border: 1px solid #e5e7eb; }
  .ds-swatch-color { height: 56px; }
  .ds-swatch-info { padding: 6px 8px; background: white; }
  .ds-swatch-name { font-size: 11px; font-weight: 600; color: #374151; }
  .ds-swatch-hex { font-size: 10px; color: #9ca3af; font-family: monospace; }

  /* Type specimens */
  .ds-type-row { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #f3f4f6; }
  .ds-type-row:last-child { border-bottom: none; }
  .ds-type-meta { font-size: 11px; color: #9ca3af; font-family: monospace; margin-bottom: 4px; }

  /* Button showcase */
  .ds-btn-row { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 16px; }

  /* Card grid */
  .ds-card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }

  /* Spacing scale */
  .ds-spacing-item { display: flex; align-items: center; gap: 16px; margin-bottom: 8px; }
  .ds-spacing-bar { background: var(--color-teal-400); height: 16px; border-radius: 4px; }
  .ds-spacing-label { font-size: 12px; font-family: monospace; color: #6b7280; white-space: nowrap; min-width: 100px; }

  /* Icon grid */
  .ds-icon-grid { display: flex; flex-wrap: wrap; gap: 20px; }
  .ds-icon-item { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 16px; border-radius: 10px; border: 1px solid #e5e7eb; min-width: 80px; }
  .ds-icon-item i { font-size: 24px; color: var(--color-navy-800); }
  .ds-icon-item span { font-size: 10px; color: #9ca3af; }

  /* Dark preview strip */
  .ds-dark-strip { background: var(--color-navy-800); padding: 32px; border-radius: 12px; margin-top: 16px; }

  /* Component preview box */
  .ds-preview { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 32px; margin-bottom: 16px; }
  .ds-preview-dark { background: var(--color-navy-800); border-color: var(--color-navy-700); }
</style>

