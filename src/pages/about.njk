---
layout: layouts/base.njk
title: About Us
description: Samaritan Bio builds intelligent medical devices for early detection of kidney injury and other critical-care complications. Join our team in Bengaluru.
permalink: /about/
---

<!-- About Hero -->
<section class="deck-section landing-hero">
  <div class="container text-center">
    <p class="eyebrow reveal">About Us</p>
    <h1 class="reveal reveal-delay-1">About Samaritan Bio</h1>
    <p class="hero-lead reveal reveal-delay-2">
      Samaritan Bio builds intelligent medical devices for early detection
      of kidney injury and other critical-care complications, combining
      sensing, diagnostics, and clinical workflow design.
    </p>
  </div>
  <img src="/assets/hero-gradient.svg" alt="" class="hero-gradient" aria-hidden="true">
</section>

<!-- Vision Section -->
<section class="deck-section vision-section">
  <div class="container">
    <p class="eyebrow eyebrow-left eyebrow-accent">Our Vision</p>
    <h2 class="reveal">Urine is the body's most accessible <span class="text-accent">real-time diagnostic signal</span></h2>
    <p class="vision-lead reveal reveal-delay-1">
      Unlike blood draws that require invasive sampling, urine is continuously produced and naturally collected in
      catheterized patients. It carries a rich constellation of biomarkers — and no one is systematically reading them.
    </p>
    <p class="vision-body reveal reveal-delay-2">
      Samaritan is building AI models that decode this signal in real-time. Our first application is Acute Kidney
      Injury prediction. Our ambition is far greater — a comprehensive biomarker intelligence platform for the human body.
    </p>
  </div>
</section>

<!-- Team -->
<section class="deck-section-short team-section" id="team">
  <div class="container">
    <p class="eyebrow">Our Team</p>
    <h2 class="reveal">Meet the Founders</h2>
    <div class="team-grid">
      <div class="card card-light card-md card-hoverable team-card reveal">
        <img src="/assets/karan.jpg" alt="Karan Rao" class="team-photo">
        <h4>Karan Rao</h4>
        <p class="role">CTO</p>
        <p class="bio">BS ECE — Carnegie Mellon University. Entrepreneur (Swachh). Technology consultant. Ex-VC.</p>
        <div class="team-social">
          <a href="https://in.linkedin.com/in/raokaran" target="_blank" rel="noopener">
            <i class="ph-fill ph-linkedin-logo" aria-hidden="true"></i> LinkedIn
          </a>
        </div>
      </div>
      <div class="card card-light card-md card-hoverable team-card reveal reveal-delay-1">
        <img src="/assets/raghav.jpg" alt="Raghav Behl" class="team-photo">
        <h4>Raghav Behl</h4>
        <p class="role">CEO</p>
        <p class="bio">BS ECE, MS AI — Carnegie Mellon University. Software consultant. Ex-Merkle Science, Ex-Inzane Labs.</p>
        <div class="team-social">
          <a href="https://www.linkedin.com/in/raghav-behl-85486a42/" target="_blank" rel="noopener">
            <i class="ph-fill ph-linkedin-logo" aria-hidden="true"></i> LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Advisors & Mentors -->
    <div class="advisors-section">
      <h3 class="advisors-heading reveal">Clinical Advisors & Mentors</h3>
      <div class="advisors-grid">
        {% for person in site.team.advisors %}
        <div class="card card-light card-sm card-hoverable advisor-card reveal{% if loop.index > 1 %} reveal-delay-{{ loop.index0 }}{% endif %}">
          <div class="advisor-avatar">{{ person.initials }}</div>
          <div class="advisor-info">
            <h4>{{ person.name }}</h4>
            <p class="role">{{ person.role }}</p>
            <p class="bio">{{ person.bio }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

