<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Favicon -->
  <link rel="icon" href="/assets/favicon.ico" sizes="32x32">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <!-- Canonical -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/samaritan-og-image.jpg">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/samaritan-og-image.jpg">

  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;600;700&family=TASA+Explorer:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.0.3/src/fill/style.css">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css">

  {% block head %}{% endblock %}
</head>

<body>
  <!-- Skip Link -->
  <a href="#main" class="skip-link">Skip to content</a>

  <!-- Navigation -->
  <nav class="landing-nav">
    <a href="/" class="nav-brand"><img src="/assets/samaritan-logo-wordmark-black.svg" alt="samaritan.bio" class="nav-logo"></a>
    <div class="nav-links">
      <div class="nav-dropdown">
        <a href="/about/"{% if page.url == "/about/" %} class="active"{% endif %}>About <svg class="nav-chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l3 3 3-3"/></svg></a>
        <div class="nav-dropdown-menu">
          <div class="nav-dropdown-menu-inner">
            <a href="/about/">Company</a>
            <a href="/about/#team">Team</a>
            <a href="/about/#careers">Careers</a>
          </div>
        </div>
      </div>
      <a href="/arobag/"{% if page.url == "/arobag/" %} class="active"{% endif %}>AroBag</a>
      <a href="/blog/"{% if page.url.startsWith("/blog/") %} class="active"{% endif %}>Blog</a>
      <a href="/savings-calculator/"{% if page.url == "/savings-calculator/" %} class="active"{% endif %}>Savings Calculator</a>
      {# TODO: Remove these two dev-only nav links before launch #}
      <a href="/design-system/"{% if page.url == "/design-system/" %} class="active"{% endif %}>Design</a>
      <a href="/backup/"{% if page.url == "/backup/" %} class="active"{% endif %}>Backup</a>
    </div>
    <a href="/#contact" class="nav-cta">Get in Touch</a>
    <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div class="mobile-nav-overlay" aria-hidden="true"></div>
  <div class="mobile-nav-drawer" role="dialog" aria-label="Navigation menu">
    <button class="mobile-nav-close" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
    <div class="mobile-nav-links">
      <a href="/about/"{% if page.url == "/about/" %} class="active"{% endif %}>About</a>
      <div class="mobile-nav-sub">
        <a href="/about/">Company</a>
        <a href="/about/#team">Team</a>
        <a href="/about/#careers">Careers</a>
      </div>
      <a href="/arobag/"{% if page.url == "/arobag/" %} class="active"{% endif %}>AroBag</a>
      <a href="/blog/"{% if page.url.startsWith("/blog/") %} class="active"{% endif %}>Blog</a>
      <a href="/savings-calculator/"{% if page.url == "/savings-calculator/" %} class="active"{% endif %}>Savings Calculator</a>
      {# TODO: Remove these two dev-only nav links before launch #}
      <a href="/design-system/"{% if page.url == "/design-system/" %} class="active"{% endif %}>Design</a>
      <a href="/backup/"{% if page.url == "/backup/" %} class="active"{% endif %}>Backup</a>
    </div>
    <a href="/#contact" class="mobile-nav-cta">Get in Touch</a>
  </div>

  <!-- Main Content -->
  <main id="main">
    {% block content %}{{ content | safe }}{% endblock %}
  </main>

  <!-- Footer -->
  <footer class="landing-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand-col">
          <a href="/" class="footer-brand"><img src="/assets/samaritan-logo-wordmark-black.svg" alt="samaritan.bio" class="footer-logo"></a>
          <p>Pioneering automated urine analysis systems for early detection of AKI and improved patient outcomes in critical care environments.</p>
          <div class="footer-contact">
            <a href="mailto:{{ site.email }}"><i class="ph-fill ph-envelope-simple" aria-hidden="true"></i> {{ site.email }}</a>
            <a href="tel:{{ site.phone | replace(' ', '') }}"><i class="ph-fill ph-phone" aria-hidden="true"></i> {{ site.phone }}</a>
          </div>
          <div class="footer-addresses">
            <p><strong>Registered Office:</strong> {{ site.registeredOffice }}</p>
            <p><strong>Corporate Office:</strong> {{ site.corporateOffice }}</p>
          </div>
          <div class="footer-legal-links">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
          </div>
        </div>
        <div>
          <h4>Company</h4>
          <ul class="footer-links">
            <li><a href="/">About Us</a></li>
            <li><a href="/#team">Our Team</a></li>
            <li><a href="/#contact">Contact</a></li>
            <li><a href="/about/#careers">Careers</a></li>
          </ul>
        </div>
        <div>
          <h4>Resources</h4>
          <ul class="footer-links">
            <li><a href="/arobag/#clinical">Clinical Trials</a></li>
            <li><a href="mailto:{{ site.email }}?subject=Demo%20Request">Request Demo</a></li>
            <li><a href="/savings-calculator/">Savings Calculator</a></li>
          </ul>
        </div>
        <div>
          <h4>Subscribe</h4>
          <form class="footer-subscribe" action="mailto:{{ site.email }}?subject=Newsletter%20Signup" method="post" enctype="text/plain">
            <input type="email" name="email" placeholder="Your email address" required aria-label="Email address">
            <button type="submit">
              <i class="ph-fill ph-arrow-right" aria-hidden="true"></i>
            </button>
          </form>
        </div>
      </div>
      <div class="footer-divider"></div>
      <div class="footer-bottom-row">
        <p>&copy; {{ page.date.getFullYear() }} {{ site.companyName }} | CIN: {{ site.cin }} | All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="/js/main.js" defer></script>
  {% block scripts %}{% endblock %}
</body>

</html>
